# Get token from @BotFather
BOT_TOKEN=

# Owner chat_id — the only person who can use this bot.
# If empty, bot binds to first /start.
OWNER_CHAT_ID=

# Where JSON state is persisted (Coolify: mount volume here)
DATA_DIR=/data

# Public URL Telegram will call. Traefik strips /api, so internally it's /webhook.
WEBHOOK_BASE_URL=https://rovno-bot.agents-builder.ru

# Set only if you want to override auto-generated secret
WEBHOOK_SECRET=

# When set to "1", the bot does not touch Telegram's webhook (external tunnel manages it).
SKIP_SETWEBHOOK=
